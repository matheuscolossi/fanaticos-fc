DATABASE_URL=postgresql://usuario:senha@host.neon.tech/neondb?sslmode=require
DB_SSL=true
NODE_ENV=production
JWT_SECRET=
CORS_ORIGIN=https://seudominio.com
FRONTEND_URL=https://seudominio.com
# Nome exibido no prazo estimado. A URL/código de rastreio é informada por pedido no admin.
SHIPPING_PROVIDER=Envio padrão
# Stripe: use chaves de teste (sk_test_/pk_test_) durante o desenvolvimento.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
DEFAULT_ADMIN_EMAIL=
# Se a senha tiver #, espaço ou aspas, coloque-a entre aspas duplas (o dotenv trata # sem aspas como comentário)
DEFAULT_ADMIN_PASSWORD=
# API acadêmica mutável: desabilitada por padrão e restrita a outro host.
ENABLE_ACADEMIC_API=false
ACADEMIC_API_HOST=
COMMERCIAL_API_HOST=
# Obrigatórias somente quando ENABLE_ACADEMIC_API=true. Devem ser diferentes
# das credenciais administrativas e configuradas apenas no serviço acadêmico.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
RESEND_API_KEY=re_sua_chave_aqui
RESEND_FROM=Fanáticos FC <onboarding@resend.dev>
# Controles de verificação de e-mail (valores padrão mostrados abaixo)
EMAIL_CODE_TTL_MINUTES=15
EMAIL_CODE_MAX_ATTEMPTS=5
EMAIL_RESEND_COOLDOWN_SECONDS=60
EMAIL_RESEND_WINDOW_MINUTES=60
EMAIL_RESEND_MAX_PER_WINDOW=5
# Chave separada opcional para anonimizar IPs/contas no rate limiting.
# Se omitida, o backend usa JWT_SECRET.
RATE_LIMIT_SECRET=gere_outra_chave_aleatoria_forte_aqui
RATE_LIMIT_REGISTER_IP=10
RATE_LIMIT_REGISTER_ACCOUNT=3
RATE_LIMIT_LOGIN_IP=30
RATE_LIMIT_LOGIN_ACCOUNT=10
RATE_LIMIT_VERIFY_IP=30
RATE_LIMIT_VERIFY_ACCOUNT=10
RATE_LIMIT_RESEND_IP=15
RATE_LIMIT_RESEND_ACCOUNT=6
RATE_LIMIT_PASSWORD_RESET_IP=10
RATE_LIMIT_PASSWORD_RESET_ACCOUNT=5
RATE_LIMIT_TRACKING_IP=60
RATE_LIMIT_TRACKING_ACCOUNT=30
RATE_LIMIT_CART_IP=120
RATE_LIMIT_CART_ACCOUNT=60
RATE_LIMIT_CHECKOUT_IP=20
RATE_LIMIT_CHECKOUT_ACCOUNT=10
RATE_LIMIT_ACADEMIC_IP=30
RATE_LIMIT_API_IP=600
RATE_LIMIT_PUBLIC_READ_IP=180
