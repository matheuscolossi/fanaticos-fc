DATABASE_URL=postgresql://usuario:senha@host.neon.tech/neondb?sslmode=require
DB_SSL=true
NODE_ENV=production
JWT_SECRET=gere_uma_chave_aleatoria_forte_aqui
CORS_ORIGIN=https://seudominio.com
FRONTEND_URL=https://seudominio.com
# Stripe: use chaves de teste (sk_test_/pk_test_) durante o desenvolvimento.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
DEFAULT_ADMIN_EMAIL=admin@seudominio.com
# Se a senha tiver #, espaço ou aspas, coloque-a entre aspas duplas (o dotenv trata # sem aspas como comentário)
DEFAULT_ADMIN_PASSWORD=troque_esta_senha
# Credenciais Basic Auth usadas pelo professor no Postman (POST /products, DELETE /product/:id)
# Se não definidas, caem para DEFAULT_ADMIN_EMAIL / DEFAULT_ADMIN_PASSWORD.
BASIC_AUTH_USER=admin@seudominio.com
BASIC_AUTH_PASS=troque_esta_senha
RESEND_API_KEY=re_sua_chave_aqui
RESEND_FROM=Fanáticos FC <onboarding@resend.dev>
